# URL de l'API en production (obligatoire si le frontend est sur un autre domaine que l'API).
# Production Vercel + Railway :
# VITE_API_URL=https://clientpilot-production.up.railway.app/api
# En local, laisser vide : le proxy Vite redirige /api vers localhost:3001
VITE_API_URL=

# Identifiants de démo affichés par défaut sur la page de connexion.
# Mettre à "false" pour les masquer en production.
# VITE_SHOW_DEMO_CREDENTIALS=false

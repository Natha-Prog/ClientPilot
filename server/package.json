{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npm run db:migrate && npm run db:seed && node src/index.js",
    "start:api": "node src/index.js",
    "build": "prisma generate",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node src/seed.js",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}

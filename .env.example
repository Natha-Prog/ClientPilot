# Database
# Option A — dedicated user (after running scripts/setup-local-db.sql):
DATABASE_URL=postgresql://clientpilot:clientpilot@localhost:5432/clientpilot
DIRECT_URL=postgresql://clientpilot:clientpilot@localhost:5432/clientpilot
# Option B — local superuser (replace YOUR_PASSWORD):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/clientpilot
# DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/clientpilot
#
# Option C — Supabase (Prisma): replace [YOUR-PASSWORD]
# DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-a-long-random-string
# Comma-separated list of allowed frontend origins (no trailing slash)
# Production (Vercel frontend + Railway API):
# CLIENT_URL=https://client-pilot-qfkx.vercel.app,https://clientpilot-production.up.railway.app
# On Railway/Render full-stack deploys, the platform URL is auto-detected; set this
# when the frontend is on another domain (e.g. Vercel).
CLIENT_URL=http://localhost:5173

# Admin seed (created on first run if no users exist)
ADMIN_EMAIL=admin@clientpilot.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrateur

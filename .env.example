# Database
# Option A — dedicated user (after running scripts/setup-local-db.sql):
DATABASE_URL=postgresql://clientpilot:clientpilot@localhost:5432/clientpilot
# Option B — local superuser (replace YOUR_PASSWORD):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/clientpilot

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-a-long-random-string
# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. CLIENT_URL=https://clientpilot-1.onrender.com,https://client-pilot.netlify.app
CLIENT_URL=http://localhost:5173

# Admin seed (created on first run if no users exist)
ADMIN_EMAIL=admin@clientpilot.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrateur
